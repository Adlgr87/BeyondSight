# BeyondSight environment variables
# Copy this file to ".env" and fill only the provider you will use.

# -----------------------------
# LLM provider API keys
# -----------------------------
# Required only if you choose that provider in the UI.
GROQ_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# -----------------------------
# Local Ollama host
# -----------------------------
# Used only when provider = ollama
# Default value in app: http://localhost:11434
OLLAMA_HOST=http://localhost:11434
